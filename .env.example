# Replit sets these automatically when you attach integrations.
# Copy to .env for local backend development (optional).

PORT=5000
NODE_ENV=development

# Replit PostgreSQL (household sync, links, board metadata — full build)
# DATABASE_URL=

# Replit Object Storage (attachments — Phase 6)
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=

# Local dev fallback when object storage is not configured (optional)
# LOCAL_STORAGE_DIR=.local-object-storage
